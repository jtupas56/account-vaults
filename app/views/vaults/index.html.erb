<div class="max-w-7xl mx-auto px-6 py-8">

  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-bold text-gray-800">
      Vault
    </h1>

    <%= link_to "New Vault",
        new_vault_path,
        class: "bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-lg font-medium transition" %>
  </div>

  <div class="overflow-hidden rounded-xl border border-gray-200 shadow-sm bg-white">

    <table class="min-w-full divide-y divide-gray-200">

      <thead class="bg-gray-100">
        <tr>
          <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Site</th>
          <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">URL</th>
          <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Login</th>
          <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Password</th>
          <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Timestamp</th>
          <th class="px-6 py-4 text-center text-sm font-semibold text-gray-700">Actions</th>
        </tr>
      </thead>

      <tbody class="divide-y divide-gray-100">

        <% @vaults.each do |vault| %>

          <tr class="hover:bg-gray-50 transition">

            <td class="px-6 py-4 font-medium text-gray-800">
              <%= vault.site %>
            </td>

            <td class="px-6 py-4">
              <%= link_to vault.url,
                    vault.url,
                    target: "_blank",
                    class: "text-blue-600 hover:underline" %>
            </td>

            <td class="px-6 py-4 text-gray-700">
              <%= vault.login %>
            </td>

            <td class="px-6 py-4 font-mono text-gray-700">
              <%= vault.password %>
            </td>

            <td class="px-6 py-4 text-gray-600 whitespace-nowrap">
              <%= vault.updated_at.strftime("%-d %b %Y, %H:%M") %>
            </td>

            <td class="px-6 py-4">
              <div class="flex justify-center gap-2">

                <%= link_to "Edit",
                      edit_vault_path(vault),
                      class: "px-3 py-1 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition" %>

                <%= button_to "Delete",
                      vault,
                      method: :delete,
                      data: { turbo_confirm: "Delete this vault?" },
                      class: "px-3 py-1 bg-red-600 text-white rounded-md hover:bg-red-700 transition" %>

              </div>
            </td>

          </tr>

        <% end %>

      </tbody>

    </table>

  </div>

</div>