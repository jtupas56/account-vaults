<%= form_with(model: vault, class: "max-w-md mx-auto") do |form| %>
  <% if vault.errors.any? %>
    <div style="color: red; margin-bottom: 16px;">
      <h2><%= pluralize(vault.errors.count, "error") %> prohibited this vault from being saved:</h2>
      <ul>
        <% vault.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div style="margin-bottom: 12px;">
    <%= form.label :site, style: "display:block; font-weight:500; margin-bottom:4px;" %>
    <%= form.text_field :site, style: "width:100%; padding:8px 12px; border:1px solid #d1d5db; border-radius:6px;" %>
  </div>

  <div style="margin-bottom: 12px;">
    <%= form.label :url, style: "display:block; font-weight:500; margin-bottom:4px;" %>
    <%= form.text_field :url, style: "width:100%; padding:8px 12px; border:1px solid #d1d5db; border-radius:6px;" %>
  </div>

  <div style="margin-bottom: 12px;">
    <%= form.label :login, style: "display:block; font-weight:500; margin-bottom:4px;" %>
    <%= form.text_field :login, style: "width:100%; padding:8px 12px; border:1px solid #d1d5db; border-radius:6px;" %>
  </div>

  <div style="margin-bottom: 12px;">
    <%= form.label :password, style: "display:block; font-weight:500; margin-bottom:4px;" %>
    <%= form.text_field :password, style: "width:100%; padding:8px 12px; border:1px solid #d1d5db; border-radius:6px;" %>
  </div>

  <div style="display:flex; gap:10px; align-items:center; margin-top:16px;">
    <%= form.submit "Create Vault", style: "background:#2563eb; color:#fff; padding:8px 16px; border:none; border-radius:6px; cursor:pointer;" %>
    <%= link_to "Back", vaults_path, style: "background:#6c757d; color:#fff; padding:8px 16px; border-radius:6px; text-decoration:none;" %>
  </div>
<% end %>